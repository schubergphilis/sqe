# Template for the live integration tests. Copy to `.env` and fill in.
#
#   cp .env.example .env
#   # then run a backend-specific test, e.g.:
#   set -a; source .env; set +a
#   cargo test -p sqe-catalog --features glue backends_integration -- \
#       --ignored glue::
#
# `.env` is gitignored. Only this template is checked in.

# ---------------------------------------------------------------------------
# AWS Glue (catalog + S3 warehouse)
# ---------------------------------------------------------------------------
# AWS_PROFILE selects credentials from `~/.aws/credentials` / SSO. The
# test reads via the standard provider chain, so any combination that
# resolves a region + credentials works (env vars, instance profile,
# `aws configure sso`).
#
# AWS_REGION and the warehouse must point at the same region; Glue is
# regional and S3 buckets are too.
AWS_PROFILE=your-aws-profile
AWS_REGION=eu-central-1

# Pre-created S3 bucket for the test warehouse. The bucket itself must
# exist; the test only writes namespace metadata (no Parquet) so the
# bucket can be empty.
SQE_TEST_GLUE_WAREHOUSE=s3://your-glue-it-bucket/wh/

# ---------------------------------------------------------------------------
# AWS S3 Tables (federated via the Glue Iceberg REST endpoint)
# ---------------------------------------------------------------------------
# AWS exposes S3 Tables through two Iceberg REST surfaces; both need
# AWS SigV4 on every request. SQE's vendored iceberg-catalog-rest
# enables that path with the `aws-sigv4` cargo feature (default-on).
#
# Warehouse format is what AWS returns from /v1/config as `prefix`:
# `<account-id>:s3tablescatalog/<bucket-name>` for the federated Glue
# endpoint. Override SQE_TEST_S3TABLES_URI / _SIGNING_NAME to switch
# to the per-bucket s3tables.<region>.amazonaws.com/iceberg variant.
SQE_TEST_S3TABLES_WAREHOUSE=000000000000:s3tablescatalog/your-table-bucket
# SQE_TEST_S3TABLES_URI=https://glue.eu-central-1.amazonaws.com/iceberg
# SQE_TEST_S3TABLES_SIGNING_NAME=glue

# ---------------------------------------------------------------------------
# Hive Metastore (docker-compose.hms.yml)
# ---------------------------------------------------------------------------
# Defaults to docker-compose's localhost mapping; uncomment to override.
# SQE_TEST_HMS_URI=127.0.0.1:19083
# SQE_TEST_HMS_WAREHOUSE=s3a://warehouse/hms/

# ---------------------------------------------------------------------------
# Project Nessie (docker-compose.nessie.yml)
# ---------------------------------------------------------------------------
# SQE_TEST_NESSIE_URI=http://127.0.0.1:19121/iceberg/
# SQE_TEST_NESSIE_WAREHOUSE=warehouse

# ---------------------------------------------------------------------------
# JDBC Postgres (docker-compose.test.yml)
# ---------------------------------------------------------------------------
# SQE_TEST_PG_URL=postgres://iceberg:iceberg@localhost:15432/iceberg_catalog
# SQE_TEST_PG_WAREHOUSE=/tmp/sqe-pg-jdbc-test-warehouse
