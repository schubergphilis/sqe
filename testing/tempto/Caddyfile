{
	auto_https disable_redirects
	# The trino-jdbc okhttp client runs on the JVM, which omits the TLS SNI
	# extension for single-label hostnames like "tls-proxy" (no dot). Without
	# SNI, Caddy cannot match the site cert and aborts the handshake with an
	# internal_error alert. default_sni makes Caddy serve the tls-proxy cert
	# when the client sends no SNI. Also pin h1/h2 and an RSA internal cert,
	# which the JVM TLS stack negotiates reliably.
	default_sni tls-proxy
	servers {
		protocols h1 h2
	}
}

https://tls-proxy:8443 {
	tls {
		issuer internal
		key_type rsa2048
	}
	reverse_proxy http://sqe:8080
}
