# Copy to .env (docker compose reads it automatically). The defaults below
# all work as-is for a local run. Change the secrets before exposing this to
# anything but your laptop.

# --- Secrets (quickstart defaults; rotate for anything real) ---
KEYCLOAK_ADMIN_PASSWORD=admin
SQE_CLIENT_SECRET=sqe-secret-change-me        # Keycloak sqe-client secret; must match sqe.toml
ROOT_PASSWORD=root123                          # Keycloak 'root' user password
POLARIS_BOOTSTRAP_SECRET=polaris-root-secret   # Polaris-internal root client secret (NOT Keycloak)
S3_ACCESS_KEY=s3admin
S3_SECRET_KEY=s3adminpw

# --- Host ports (offset so this stack won't clash with other local stacks) ---
KEYCLOAK_PORT=28080
POLARIS_PORT=18181
RUSTFS_PORT=19000
RUSTFS_CONSOLE_PORT=19001
SQE_FLIGHT_PORT=60051
SQE_TRINO_PORT=18080

# --- Image ---
# Leave as-is to build SQE from this repo on first `up`. To reuse an
# already-built image instead, set SQE_IMAGE (e.g. sqe-sqe:latest).
SQE_IMAGE=sqe-quickstart:latest
