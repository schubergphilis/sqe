{
  "realm": "iceberg",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "defaultDefaultClientScopes": [
    "acr",
    "basic",
    "email",
    "profile",
    "roles",
    "web-origins",
    "catalog"
  ],
  "clientScopes": [
    {
      "name": "catalog",
      "description": "Catalog access scope for Polaris",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "service_admin",
        "description": "Service administrator (full Polaris control)"
      },
      {
        "name": "catalog_admin",
        "description": "Create/drop namespaces and tables"
      },
      {
        "name": "data_writer",
        "description": "INSERT / write table data"
      },
      {
        "name": "table_reader",
        "description": "SELECT / read table data"
      }
    ]
  },
  "clients": [
    {
      "clientId": "sqe-client",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:SQE_CLIENT_SECRET)",
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "principal_roles_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "principal_roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "groups_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "polaris-frontend-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "webOrigins": [
        "+"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "root",
      "email": "root@example.com",
      "firstName": "Root",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "$(env:ROOT_PASSWORD)",
          "temporary": false
        }
      ],
      "realmRoles": [
        "service_admin",
        "catalog_admin",
        "data_writer",
        "table_reader"
      ],
      "requiredActions": []
    },
    {
      "username": "adminuser",
      "email": "adminuser@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "adminuser123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "catalog_admin",
        "data_writer",
        "table_reader"
      ],
      "requiredActions": []
    },
    {
      "username": "testuser",
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testuser123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "table_reader"
      ],
      "requiredActions": []
    }
  ]
}
