{
  "realm": "iceberg-ranger",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "defaultDefaultClientScopes": [
    "acr",
    "basic",
    "email",
    "profile",
    "roles",
    "web-origins",
    "catalog"
  ],
  "clientScopes": [
    {
      "name": "catalog",
      "description": "Catalog access scope for Polaris",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "sqe_admin",
        "description": "SQE admin: runs GRANT/REVOKE (full Polaris control)"
      },
      {
        "name": "engineer",
        "description": "Engineer: read + write + create tables"
      },
      {
        "name": "analyst",
        "description": "Analyst: read-only"
      }
    ]
  },
  "clients": [
    {
      "clientId": "sqe-client",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:SQE_CLIENT_SECRET)",
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "polaris-frontend-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "webOrigins": [
        "+"
      ],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "carol",
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "carol123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "sqe_admin",
        "engineer",
        "analyst"
      ],
      "requiredActions": []
    },
    {
      "username": "bob",
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Engineer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "engineer",
        "analyst"
      ],
      "requiredActions": []
    },
    {
