# Copy to .env (defaults already work). Edit to change secrets/ports.
KEYCLOAK_ADMIN_PASSWORD=admin
SQE_CLIENT_SECRET=sqe-secret-change-me
S3_ACCESS_KEY=s3admin
S3_SECRET_KEY=s3adminpw
POLARIS_BOOTSTRAP_SECRET=polaris-root-secret
RANGER_ADMIN_PASSWORD=rangerR0cks!
POSTGRES_PASSWORD=rangerR0cks!

# Host port offsets (kept clear of the other quickstarts; spark-parity uses 4x prefix)
KEYCLOAK_PORT=48080
POLARIS_PORT=48181
RANGER_PORT=46080
RUSTFS_PORT=49000
RUSTFS_CONSOLE_PORT=49001
SQE_FLIGHT_PORT=60061
SQE_TRINO_PORT=48079

# SQE image (built from repo root by default)
SQE_IMAGE=sqe-quickstart:latest
