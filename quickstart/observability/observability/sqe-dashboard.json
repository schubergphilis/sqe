{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "SQE Overview",
  "tags": ["sqe"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Rows returned (rate/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(sqe_rows_returned_total[1m]))", "legendFormat": "rows/s", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Active sessions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sqe_active_sessions", "legendFormat": "sessions", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Cache hits vs misses (rate/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(sqe_cache_hits_total[1m]))", "legendFormat": "hits/s", "refId": "A" },
        { "expr": "sum(rate(sqe_cache_misses_total[1m]))", "legendFormat": "misses/s", "refId": "B" }
      ]
    },
    {
      "id": 4,
      "title": "Coordinator memory used (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sqe_coordinator_memory_used_bytes", "legendFormat": "used", "refId": "A" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "VictoriaMetrics", "value": "VictoriaMetrics" }
      }
    ]
  }
}
