# Copy to .env. AWS creds come from your profile (set AWS_PROFILE) or AWS_* env.
AWS_PROFILE=jacobbuilder
AWS_REGION=eu-central-1

# Host ports (offset to avoid clashing with other local stacks)
SQE_FLIGHT_PORT=60051
SQE_TRINO_PORT=18080

# Build SQE from source on first `up` (must include the format-version fix,
# now in main). Or point at an existing image.
SQE_IMAGE=sqe-quickstart:latest
