# Copy to .env (docker compose reads it automatically). Defaults work as-is.

# --- S3 / RustFS credentials ---
S3_ACCESS_KEY=s3admin
S3_SECRET_KEY=s3adminpw

# --- Host ports (offset so this stack won't clash with other local stacks) ---
RUSTFS_PORT=19000
RUSTFS_CONSOLE_PORT=19001
NESSIE_PORT=19120
SQE_FLIGHT_PORT=60051
SQE_TRINO_PORT=18080

# --- Image ---
# Leave as-is to build SQE from this repo on first `up`. Set to an existing
# image (e.g. sqe-sqe:latest) to skip the build.
SQE_IMAGE=sqe-quickstart:latest
