  "inspired": [
    {
      "title": "Embedded single binary",
      "body": "<code>sqe-cli --embedded</code>, a DuckDB-class single-process engine with a persistent SQLite-backed warehouse at <code>~/.sqe/warehouse/</code>."
    },
    {
      "title": "File-format table functions",
      "body": "<code>read_parquet</code>, <code>read_csv</code> (full DuckDB-parity options), and <code>read_json</code> / <code>read_json_auto</code>."
    },
    {
      "title": "Query a file directly",
      "body": "<code>SELECT * FROM 'file.parquet'</code> auto-detects parquet, csv, and json on local, S3, HTTPS, and hf:// paths."
    },
    {
      "title": "COPY … TO",
      "body": "Native <code>COPY &lt;source&gt; TO 'file' (FORMAT csv|json|parquet)</code> export, plus CTAS across formats."
    },
    {
      "title": "Network-transparent access",
      "body": "An <code>httpfs</code>-equivalent for HTTP/HTTPS/S3, the AWS provider chain, Azure ADLS Gen2, GCS, and Cloudflare R2."
    },
    {
      "title": "HuggingFace hf:// URLs",
      "body": "<code>hf://datasets/owner/name/path</code> with <code>?revision=</code> / <code>@rev</code> pinning and the <code>@~parquet</code> auto-view."
    },
    {
      "title": "CSV ergonomics",
      "body": "Extension-based delimiter + codec auto-detect (<code>.tsv</code>, <code>.gz</code>, <code>.zst</code>…) and DuckDB-friendly aliases (<code>sep</code>, <code>delim</code>, <code>header</code>)."
    },
    {
      "title": "SQL niceties",
      "body": "<code>DESCRIBE</code>, <code>SUMMARIZE</code>, <code>SELECT * EXCLUDE (…)</code>, and <code>SELECT * REPLACE (… AS col)</code>."
    }
  ],
  "gaps": [
    {
      "feature": "FROM-first syntax (<code>FROM t SELECT …</code>)",
      "reason": "DataFusion parser does not support it"
    },
    {
      "feature": "Struct / list / map literal sugar",
      "reason": "Partial, nested types work, the literal syntax is less ergonomic"
    },
    {
      "feature": "List comprehensions, lambdas",
      "reason": "DataFusion does not support them"
    },
    {
      "feature": "<code>PIVOT</code> / <code>UNPIVOT</code>",
      "reason": "DataFusion parser does not support it"
    },
    {
      "feature": "<code>ASOF JOIN</code>",
      "reason": "Open upstream issue, not yet landed"
    },
    {
      "feature": "<code>postgres</code> / <code>mysql</code> / <code>sqlite</code> connectors",
      "reason": "Positioning: SQE is Iceberg-first"
    },
    {
      "feature": "<code>spatial</code>, <code>vss</code>, <code>fts</code>, <code>excel</code>",
      "reason": "Niche, use a purpose-built engine"
    },
    {
      "feature": "HuggingFace glob (<code>**/*.parquet</code>)",
      "reason": "In progress, tree-API cache landed, object-store wiring next"
    }
  ]
}
