# Chapter 1: The Catalog Landscape
direction: right

glue: AWS Glue {
  style.fill: "#ff9900"
  style.font-color: "#ffffff"
  label: "AWS Glue Catalog\n(AWS-only, IAM-locked)"
}

unity: Unity Catalog {
  style.fill: "#ff3621"
  style.font-color: "#ffffff"
  label: "Unity Catalog\n(Databricks gravity well)"
}

polaris: Apache Polaris {
  style.fill: "#2e7d32"
  style.font-color: "#ffffff"
  label: "Apache Polaris\n(Pure REST, no opinions)"
}

nessie: Nessie {
  style.fill: "#5c6bc0"
  style.font-color: "#ffffff"
  label: "Nessie\n(Git-like versioning)"
}

spec: Iceberg REST Spec {
  style.fill: "#1565c0"
  style.font-color: "#ffffff"
  style.stroke-width: 3
}

sqe: SQE {
  style.fill: "#00695c"
  style.font-color: "#ffffff"
  style.stroke-width: 3
}

glue -> spec: partial
unity -> spec: partial
polaris -> spec: full
nessie -> spec: full

spec -> sqe: standard protocol
