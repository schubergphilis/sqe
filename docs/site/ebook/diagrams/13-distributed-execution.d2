# Chapter 13: Distributed Execution Architecture
direction: down

client: Client {
  shape: person
}

coordinator: Coordinator {
  style.fill: "#1565c0"
  style.font-color: "#ffffff"

  flight: Flight SQL Server
  planner: Query Planner
  policy: Policy Enforcer
  scheduler: Weighted Scheduler
  tracker: Query Tracker
}

worker1: Worker 1 {
  style.fill: "#2e7d32"
  style.font-color: "#ffffff"

  exec: DataFusion Executor
  flight_w: Flight Service
}

worker2: Worker 2 {
  style.fill: "#2e7d32"
  style.font-color: "#ffffff"

  exec: DataFusion Executor
  flight_w: Flight Service
}

polaris: Polaris Catalog {
  style.fill: "#6a1b9a"
  style.font-color: "#ffffff"
}

s3: S3 Storage {
  shape: cylinder
  style.fill: "#e65100"
  style.font-color: "#ffffff"
}

client -> coordinator.flight: "SQL + JWT"
coordinator.planner -> coordinator.policy: "enforce"
coordinator.policy -> coordinator.scheduler: "split fragments"
coordinator.scheduler -> worker1.flight_w: "Fragment A + JWT"
coordinator.scheduler -> worker2.flight_w: "Fragment B + JWT"

worker1.exec -> polaris: "JWT → credentials"
worker2.exec -> polaris: "JWT → credentials"

worker1.exec -> s3: "Read (as Alice)"
worker2.exec -> s3: "Read (as Alice)"

worker1.flight_w -> coordinator.tracker: "Arrow batches"
worker2.flight_w -> coordinator.tracker: "Arrow batches"

coordinator.flight -> client: "Combined results"
