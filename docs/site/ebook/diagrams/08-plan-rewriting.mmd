%%{init: {'theme': 'dark'}}%%
flowchart TB
    subgraph before["Before Policy Rewrite"]
        P1["Projection: name, salary"] --> F1["Filter: dept = eng"]
        F1 --> TS1["TableScan: employees"]
    end

    subgraph after["After Policy Rewrite"]
        P2["Projection: name, MASKED salary"] --> F2["Filter: dept = eng"]
        F2 --> RF["Row Filter: clearance >= 3"]
        RF --> TS2["TableScan: employees"]
    end

    before -->|"PolicyEnforcer.evaluate"| after

    style RF fill:#c62828,color:#fff
    style P2 fill:#e65100,color:#fff
