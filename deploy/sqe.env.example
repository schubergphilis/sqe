# SQE-specific env vars to add to quickstart/full/.env
# when using docker-compose.sqe.yml overlay

# SQE Keycloak client (must be created in realm config)
# DEP-10: obviously-invalid sentinel. Replace before use; never ship this
# value to a non-dev environment (a publicly-known secret protects nothing).
SQE_CLIENT_SECRET=CHANGEME_DO_NOT_USE_IN_PROD
